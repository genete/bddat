# ================================
# BDDAT - Configuration Template
# ================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Replace placeholder values with your actual configuration
# 3. NEVER commit .env to version control (it's in .gitignore)
#

# Flask Application
FLASK_APP=run.py
FLASK_ENV=development

# Security Configuration
# ⚠️ CRITICAL: Generate a secure key for production!
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-cambiar-en-produccion

# Database Configuration
# Format: postgresql://username:password@host:port/database
# Development example:
DATABASE_URL=postgresql://bddat_admin:your_password_here@localhost:5432/bddat

# Optional: Debug mode (set to False in production)
DEBUG=True

# Optional: Database connection pool settings
# SQLALCHEMY_POOL_SIZE=5
# SQLALCHEMY_MAX_OVERFLOW=10

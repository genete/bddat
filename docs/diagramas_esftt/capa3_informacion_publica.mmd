%% Fuente: ESTRUCTURA_FTT.json | Sincronizado: 2026-03-22
flowchart TD
    INI([INICIO INFORMACION PUBLICA])
    MR_INI{Motor INICIAR}
    BLQ([FASE BLOQUEADA])
    MR_FIN{Motor FINALIZAR}
    PEND([TRAMITE PENDIENTE])
    FIN([FASE CERRADA — resultado manual])

    INI --> MR_INI
    MR_INI -->|BLOQUEAR: DR_NO_DUP bloqueante| BLQ
    MR_INI -->|Permitido| BOE_1 & BOP_1 & PRS_1 & TAB_1 & POR_1 & ALE_1 & ANL_1

    subgraph SG_PUB["PUBLICACIONES — tramites paralelos"]
        direction LR
        subgraph SG_BOE["ANUNCIO_BOE · patron C+E+F"]
            BOE_1[REDACTAR] --> BOE_2[FIRMAR] --> BOE_3[NOTIFICAR BOE]
            BOE_3 --> BOE_4([ESPERAR publicacion])
            BOE_4 --> BOE_5[INCORPORAR justif. pub.]
            BOE_5 --> BOE_6([ESPERAR plazo alegaciones])
        end
        subgraph SG_BOP["ANUNCIO_BOP · patron C+E+F"]
            BOP_1[REDACTAR] --> BOP_2[FIRMAR] --> BOP_3[NOTIFICAR BOP]
            BOP_3 --> BOP_4([ESPERAR publicacion])
            BOP_4 --> BOP_5[INCORPORAR justif. pub.]
            BOP_5 --> BOP_6([ESPERAR plazo alegaciones])
        end
        subgraph SG_PRS["ANUNCIO_PRENSA · patron C+E+F"]
            PRS_1[REDACTAR] --> PRS_2[FIRMAR] --> PRS_3[NOTIFICAR Prensa]
            PRS_3 --> PRS_4([ESPERAR publicacion])
            PRS_4 --> PRS_5[INCORPORAR justif. pub.]
            PRS_5 --> PRS_6([ESPERAR plazo alegaciones])
        end
        subgraph SG_TAB["TABLON_AYUNTAMIENTOS · patron C+E"]
            TAB_1[REDACTAR] --> TAB_2[FIRMAR] --> TAB_3[NOTIFICAR Aytos]
            TAB_3 --> TAB_4([ESPERAR tablon])
            TAB_4 --> TAB_5[INCORPORAR certif. exposicion]
        end
        subgraph SG_POR["PORTAL_TRANSPARENCIA · patron D"]
            POR_1[REDACTAR] --> POR_2[FIRMAR] --> POR_3[PUBLICAR portal]
            POR_3 --> POR_4([ESPERAR plazo alegaciones])
        end
    end

    subgraph SG_ALEGA["GESTION DE ALEGACIONES — tramites paralelos"]
        subgraph SG_ALE["RECEPCION_ALEGACION · patron EC · repetible por alegacion"]
            ALE_1[INCORPORAR alegacion] --> ALE_2[ANALIZAR]
            ALE_2 --> ALE_3[REDACTAR traslado] --> ALE_4[FIRMAR] --> ALE_5[NOTIFICAR Titular]
            ALE_5 --> ALE_6([ESPERAR respuesta Titular])
            ALE_6 -->|nueva alegacion| ALE_1
        end
        subgraph SG_ANL["ANALISIS_ALEGACIONES · patron A · doc al pool para resolucion"]
            ANL_1[ANALIZAR alegaciones]
        end
    end

    BOE_6 & BOP_6 & PRS_6 & TAB_5 & POR_4 & ALE_6 & ANL_1 --> MR_FIN
    MR_FIN -->|BLOQUEAR: tramites pendientes| PEND
    MR_FIN -->|OK| FIN

    classDef amarillo fill:#FFD700,stroke:#555,color:#000
    classDef org fill:#DDA0DD,stroke:#444,color:#000
    classDef tit fill:#90EE90,stroke:#444,color:#000
    classDef esp fill:#FFE4B5,stroke:#555,color:#000

    class INI,BLQ,PEND,FIN amarillo
    class BOE_3,BOP_3,PRS_3,TAB_3 org
    class BOE_4,BOP_4,PRS_4,TAB_4 org
    class ALE_5 tit
    class ALE_6 tit
    class BOE_6,BOP_6,PRS_6,POR_4 esp

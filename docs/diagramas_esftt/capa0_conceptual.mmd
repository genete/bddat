---
title: ESFTT — Modelo Conceptual (Capa 0)
---
graph TD
    EXP["<b>EXPEDIENTE</b><br/>Agrupación lógica de tramitación<br/>para un fin proyectado"]

    subgraph procedimental["Jerarquía procedimental"]
        SOL["<b>SOLICITUD</b><br/>Describe lo que se solicita.<br/>Se clasifica por tipos"]
        PROY["<b>PROYECTO</b><br/>Instalación objeto del expediente.<br/>Se tramita con solicitudes"]
        FASE["<b>FASE</b><br/>Etapa del procedimiento"]
        TRAM["<b>TRÁMITE</b><br/>Unidad de gestión, agrupa tareas"]
        TAREA["<b>TAREA</b><br/>Acción concreta y registrable"]
        PAT["<b>PATRÓN</b><br/>Secuencia tipo reutilizable"]
        TAT["<b>TAREA ATÓMICA</b><br/>ANALIZAR<br/>REDACTAR<br/>FIRMAR<br/>NOTIFICAR<br/>PUBLICAR<br/>INCORPORAR<br/>ESPERAR_PLAZO"]
    end

    subgraph documental["Estructura documental"]
        POOL["<b>POOL DOCUMENTAL</b><br/>Conjunto de documentos<br/>asociados a ese expediente"]
        DOC["<b>DOCUMENTO</b><br/>Fuente de verdad administrativa:<br/>qué ocurrió y cuándo"]
    end

    EXP -->|"tiene 1"| PROY
    EXP -->|"tiene 1(+)"| SOL
    EXP -->|"tiene 1"| POOL

    SOL -->|"pasa por 1(+)"| FASE
    FASE -->|"contiene 1(+)"| TRAM
    TRAM -->|"ejecuta 1(+)"| TAREA
    TAREA -->|"sigue un"| PAT
    PAT -->|"combina"| TAT

    POOL -->|"contiene"| DOC
    TAREA <-->|"consume / produce"| POOL

    style EXP fill:#1a5276,color:#fff,stroke:#1a5276
    style PROY fill:#1f618d,color:#fff,stroke:#1f618d
    style SOL fill:#1f618d,color:#fff,stroke:#1f618d
    style FASE fill:#2874a6,color:#fff,stroke:#2874a6
    style TRAM fill:#2e86c1,color:#fff,stroke:#2e86c1
    style TAREA fill:#3498db,color:#fff,stroke:#3498db
    style PAT fill:#7fb3d3,color:#000,stroke:#7fb3d3
    style TAT fill:#aed6f1,color:#000,stroke:#aed6f1
    style POOL fill:#1e8449,color:#fff,stroke:#1e8449
    style DOC fill:#27ae60,color:#fff,stroke:#27ae60
